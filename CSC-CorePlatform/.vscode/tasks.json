{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CSC: Build Same-Origin Bundle",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build:same-origin"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CSC: Preview Same-Origin Apps",
      "type": "shell",
      "command": "npm",
      "args": ["run", "preview:same-origin"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "group": "build",
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 1,
              "message": 0
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "npm run preview:same-origin",
            "endsPattern": "Same-origin local server running at http://localhost:"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    }
  ]
}